# Build the package with the canonical toolchain (node + tsc) ...
FROM node:24-slim AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm clean-install
COPY . .
RUN npm run dist

# ... then run the bun:test suite on bun. The whole tree - including
# node_modules (bignumber.js) - is carried over so bun can resolve the imports
# directly from the TypeScript sources under src/ and bun/.
FROM oven/bun:1
WORKDIR /app
COPY --from=build /app /app
