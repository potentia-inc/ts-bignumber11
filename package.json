{
  "name": "@potentia/bignumber11",
  "version": "1.0.0",
  "description": "cross-runtime utilities and test matchers for bignumber.js^11.0.0 on node.js, bun and deno",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "scripts": {
    "clean": "rimraf dist",
    "dist": "tsc",
    "dist:release": "tsc --sourceMap false",
    "lint": "eslint --fix .",
    "pretty": "prettier --write .",
    "fix": "npm run lint && npm run pretty",
    "test:node": "node --test --experimental-test-coverage 'dist/test/**/*.js'",
    "test:jest": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:vitest": "vitest run",
    "test:bun": "bun test bun/",
    "test:deno": "deno test -A dist/test/",
    "test": "npm run dist && npm run test:node && npm run test:jest && npm run test:vitest"
  },
  "author": "Potentia Computing Inc.",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@tsconfig/node24": "^24.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "bignumber.js": "^11.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "bignumber.js": "^11.0.0"
  },
  "exports": {
    ".": "./index.js",
    "./type": "./type.js",
    "./matcher/jest": "./matcher/jest.js",
    "./matcher/vitest": "./matcher/vitest.js",
    "./matcher/bun": "./matcher/bun.js"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
